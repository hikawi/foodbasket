{
  "db_name": "PostgreSQL",
  "query": "\n    SELECT t.id, t.name, t.slug, t.created_at, t.updated_at, t.deleted_at\n    FROM tenants t\n    INNER JOIN staff_profiles sp ON sp.tenant_id = t.id\n    WHERE sp.user_id = $1\n    ORDER BY name\n    OFFSET $2\n    LIMIT $3\n    ",
