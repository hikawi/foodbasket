{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            p.id, \n            p.tenant_id, \n            p.branch_id, \n            p.name, \n            p.statements AS \"statements: Json<PolicyDocument>\", \n            p.created_at, \n            p.updated_at, \n            p.deleted_at\n        FROM policies p\n        INNER JOIN assignments a ON a.policy_id = p.id\n        WHERE a.system_profile_id = $1\n          AND p.deleted_at IS NULL \n          AND a.scope_type = 'system'::scope_type\n        ",
