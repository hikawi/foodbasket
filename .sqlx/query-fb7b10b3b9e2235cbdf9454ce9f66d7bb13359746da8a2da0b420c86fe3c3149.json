{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT sp.*, COUNT(*) OVER() as \"total_count!\"\n        FROM staff_profiles sp\n        WHERE sp.tenant_id = $1 AND sp.deleted_at IS NULL AND EXISTS (\n              SELECT 1 FROM staff_profiles_branches spb\n              WHERE spb.staff_profile_id = sp.id\n              AND spb.branch_id = $2\n        )\n        ORDER BY sp.id\n        OFFSET $3\n        LIMIT $4\n        ",
