# Caddyfile for your own server setup.

http://api.foodbasket.localhost:80 {
    reverse_proxy localhost:8080
}

http://admin.foodbasket.localhost:80 {
	reverse_proxy localhost:3003
}

http://twinbells.foodbasket.localhost:80 {
	reverse_proxy localhost:3001
}

http://foodbasket.localhost:80 {
	reverse_proxy localhost:3000
}

http://twinbells.pos.foodbasket.localhost:80 {
	reverse_proxy localhost:3002
}
