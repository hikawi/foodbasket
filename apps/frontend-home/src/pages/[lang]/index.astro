---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlaceholderProfile from "../../components/home/PlaceholderProfile.vue";
import { getTranslations } from "../../utils/i18n";

const translations = await getTranslations(Astro.currentLocale);
---

<BaseLayout title={translations.index.title} description={translations.index.description}>
  <PlaceholderProfile tl={translations} client:load />
</BaseLayout>
